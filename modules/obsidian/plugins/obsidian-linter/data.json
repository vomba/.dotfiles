{
  "lintOnSave": true,
  "recordLintOnSave": true,
  "displayChanged": true,
  "foldersToIgnore": [
    "06 - Archive"
  ],
  "linterLocale": "system",
  "ruleConfigs": {
    "yaml-key-sort": {
      "yaml-key-sort-order": "created, tags, aliases, url, source, type, status, language, related, priority, start_date, end_date",
      "enabled": true
    },
    "format-tags-in-yaml": {
      "enabled": true
    },
    "format-yaml-array": {
      "enabled": true
    },
    "capitalize-headings": {
      "enabled": true,
      "style": "First letter"
    },
    "trailing-spaces": {
      "enabled": true
    },
    "heading-blank-lines": {
      "enabled": true
    },
    "empty-line-around-code-fences": {
      "enabled": true
    },
    "empty-line-around-tables": {
      "enabled": true
    }
  }
}
