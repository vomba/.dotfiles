# Runtime observation data (auto-generated, can be large)
*.jsonl
observations.archive/

# Observer runtime state (.observer.pid, .observer-signal-counter, etc.)
.observer*
observer.log
.last-purge

# Temp files
.observer-tmp/
*.lock

# Per-project runtime data (same patterns as above)
projects/*/*.jsonl
projects/*/observations.archive/
projects/*/.observer*
projects/*/observer.log
projects/*/.last-purge
projects/*/.observer-tmp/
projects/*/*.lock

# Project registry — machine-specific paths + last_seen timestamps
# Instincts/evolved are still tracked and shared across machines
projects.json
projects/*/project.json
